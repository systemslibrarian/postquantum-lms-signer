<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>PostQuantum.Lms.Hybrid</RootNamespace>
    <AssemblyName>PostQuantum.LMS.Signer.Hybrid</AssemblyName>

    <PackageId>PostQuantum.LMS.Signer.Hybrid</PackageId>
    <Title>PostQuantum.LMS.Signer.Hybrid</Title>
